{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/edpa/scripts/hooks/validate_on_save.sh",
            "timeout": 10,
            "statusMessage": "Validating syntax..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/edpa/scripts/hooks/edpa_post_commit.sh",
            "timeout": 10,
            "statusMessage": "EDPA commit info"
          }
        ]
      }
    ]
  }
}
